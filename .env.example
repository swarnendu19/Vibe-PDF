# ── PublishEngine Environment Variables ──────────────────────────────────────
# Copy to .env.local for local development. Never commit .env.local.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/publishengine"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Orchestrator API ──────────────────────────────────────────────────────────
ORCHESTRATOR_URL="http://localhost:8080"

# ── AI Provider ───────────────────────────────────────────────────────────────
# Vercel AI SDK uses this for the active LLM provider
OPENAI_API_KEY="sk-..."
# or
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_GENERATIVE_AI_API_KEY="AI..."

# ── Object Storage (Cloudflare R2) ────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="publishengine"
R2_PUBLIC_URL=""

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
